# Copy to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# Public site URL (optional on Vercel — auto-detected)
NEXT_PUBLIC_SITE_URL=

# Contact
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=

# Social
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Resume
NEXT_PUBLIC_RESUME_DRIVE_VIEW_URL=
NEXT_PUBLIC_RESUME_DRIVE_DOWNLOAD_URL=
NEXT_PUBLIC_RESUME_FILE_NAME=KarunaVasu_SoftwareEngineer_Resume.pdf

# Research
NEXT_PUBLIC_IEEE_PUBLICATION_URL=

# Product / demo URLs (internal or staging — keep out of source)
NEXT_PUBLIC_BOTVETA_LIVE_URL=
NEXT_PUBLIC_BOTVETA_BUILD_URL=
NEXT_PUBLIC_IVR_LIVE_URL=

# Location (display only)
NEXT_PUBLIC_LOCATION_CITY=Mangalore, IN
NEXT_PUBLIC_LOCATION_LAT=
NEXT_PUBLIC_LOCATION_LON=
NEXT_PUBLIC_LOCATION_UTC=+05:30
